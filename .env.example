# Required: Anthropic API key for the SEO analyser LLM calls.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: PageSpeed Insights API key. The endpoint works without one,
# but a key raises the rate limit from 25k/day to 25k/100s.
# Get one at https://console.cloud.google.com/apis/credentials
# (enable "PageSpeed Insights API" first).
PAGESPEED_API_KEY=
